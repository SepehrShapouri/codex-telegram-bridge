{
  "name": "codex-telegram-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Local Telegram bridge for Codex CLI sessions running on your laptop.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "grammy": "^1.38.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
